# ============================================================
# XOX Arena - Environment Variables
# Render.com üzerinde ortam değişkenlerini buradan ayarlayın.
# ============================================================

# MongoDB Atlas bağlantı dizesi (zorunlu değil - yoksa in-memory kullanılır)
# Örnek: mongodb+srv://kullanici:sifre@cluster0.xxxxx.mongodb.net/
MONGO_URI=""

# JWT imzalama secret (production'da mutlaka değiştirin!)
JWT_SECRET="xox-super-secret-key-change-this-in-production"

# Uygulama URL (Render.com otomatik sağlar, gerekirse manuel set edin)
APP_URL="https://your-app-name.onrender.com"

# Node ortamı (production için "production" yapın)
NODE_ENV="production"

# ─── Web Push (PWA Push Bildirimleri) ───────────────────────────────────────
# VAPID anahtarlarını üretmek için terminalde şunu çalıştırın:
#   npx web-push generate-vapid-keys
# Çıkan Public Key ve Private Key'i buraya yapıştırın.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Bildirimlerde görünecek iletişim e-postası (mailto: formatında)
VAPID_EMAIL="mailto:admin@xoxarena.com"
